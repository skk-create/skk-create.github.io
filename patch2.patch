+
+/* Styling voor de tech-logo's in de skills */
+.tech-logo {
+  width: 22px;
+  height: 22px;
+  object-fit: contain;
+}
+
+.skill-item {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  margin-bottom: 8px;
+  margin-top: 15px;
+  font-size: 0.95rem;
+  color: var(--text-bright, #fff);
+}
+
+.skill-info {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+}
+
+.percentage {
+  color: var(--text-dim, #a0a0c0);
+  font-size: 0.85rem;
+}
+
+/* De laad/voortgangs-balken */
+.progress-bar {
+  width: 100%;
+  height: 6px;
+  background: rgba(255, 255, 255, 0.08);
+  border-radius: 4px;
+  overflow: hidden;
+}
+
+.progress-fill {
+  height: 100%;
+  background: #dd0404;
+  border-radius: 4px;
+  transition: width 1s ease-in-out;
+}
+
+.diagnostics-container {
+  margin-top: 40px;
+  margin-bottom: 60px;
+  padding-top: 20px;
+  border-top: 1px solid rgba(255, 255, 255, 0.1);
+  font-family: inherit;
+}
+
+.diagnostics-heading {
+  font-family: 'Playfair Display', serif;
+  font-size: 2rem;
+  font-weight: 700;
+  letter-spacing: 1px;
+  color: var(--text-bright, #fff);
+  margin-bottom: 10px;
+}
+
+.diagnostics-sub {
+  color: #aaa;
+  font-size: 0.95rem;
+  margin-bottom: 30px;
+}
+
+.skills-grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
+  gap: 20px;
+}
+
+.skill-card h3 {
+  font-size: 0.85rem;
+  letter-spacing: 2px;
+  color: #ffaa33;
+  margin-bottom: 10px;
+}
